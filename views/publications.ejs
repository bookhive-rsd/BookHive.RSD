<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport"
    content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes, viewport-fit=cover">
  <meta name="theme-color" content="#0a66c2">
  <title>Publications - BookHive</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/responsive-zoom.css">
  <link rel="stylesheet" href="/css/chat.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
  <style>
    /* ── Publications page styles ── */
    .pub-page-wrap {
      max-width: 700px;
      margin: 0 auto;
      padding: 0 1rem 3rem;
    }

    .pub-page-title {
      text-align: center;
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--text-color);
      margin-bottom: 1.5rem;
    }

    /* Post composer */
    .pub-composer {
      background: #fff;
      border: 1px solid #e0e0e0;
      border-radius: 10px;
      padding: 1.25rem;
      margin-bottom: 1.5rem;
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.07);
    }

    .pub-composer h3 {
      font-size: 1rem;
      font-weight: 600;
      color: var(--text-color);
      margin-bottom: 0.75rem;
    }

    #publication-editor-container {
      border: 1px solid #ddd;
      border-radius: 6px;
      overflow: hidden;
      margin-bottom: 0.75rem;
    }

    #publication-editor {
      min-height: 100px;
    }

    .pub-file-label {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      color: var(--primary-color);
      font-weight: 600;
      cursor: pointer;
      font-size: 0.9rem;
      margin-bottom: 0.75rem;
    }

    .pub-file-label:hover {
      text-decoration: underline;
    }

    #file-previews {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
      gap: 0.5rem;
      margin-bottom: 0.75rem;
    }

    #file-previews img {
      width: 100%;
      height: 80px;
      object-fit: cover;
      border-radius: 4px;
      border: 1px solid #ddd;
    }

    .pub-submit-row {
      display: flex;
      justify-content: flex-end;
    }

    .pub-submit-btn {
      background: var(--primary-color);
      color: #fff;
      border: none;
      border-radius: 20px;
      padding: 0.5rem 1.5rem;
      font-weight: 700;
      font-size: 0.95rem;
      cursor: pointer;
      transition: background 0.2s;
    }

    .pub-submit-btn:hover {
      background: var(--primary-hover);
    }

    .pub-submit-btn:disabled {
      background: #bbb;
      cursor: not-allowed;
    }

    .pub-msg {
      margin-top: 0.5rem;
      font-size: 0.9rem;
    }

    .pub-msg.error {
      color: var(--error-color);
    }

    .pub-msg.success {
      color: var(--success-color);
    }

    /* Publication card */
    .pub-card {
      background: #fff;
      border: 1px solid #e0e0e0;
      border-radius: 10px;
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.07);
      margin-bottom: 1.25rem;
      overflow: hidden;
    }

    .pub-card-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.85rem 1rem 0;
    }

    .pub-avatar {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: linear-gradient(135deg, #667eea, #764ba2);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 1.1rem;
      color: #fff;
      flex-shrink: 0;
    }

    .pub-meta .pub-author {
      font-weight: 600;
      font-size: 0.95rem;
      color: var(--text-color);
    }

    .pub-meta .pub-date {
      font-size: 0.78rem;
      color: var(--light-text);
    }

    .pub-body {
      padding: 0.75rem 1rem;
      font-size: 0.93rem;
      color: var(--text-color);
      line-height: 1.6;
    }

    .pub-body ul,
    .pub-body ol {
      padding-left: 1.5rem;
      margin-bottom: 0.5rem;
    }

    .pub-body a {
      color: var(--primary-color);
      text-decoration: underline;
    }

    /* Image carousel */
    .pub-carousel {
      position: relative;
      background: #f0f2f5;
    }

    .pub-carousel-img {
      width: 100%;
      max-height: 380px;
      object-fit: contain;
      display: none;
    }

    .pub-carousel-img.active {
      display: block;
    }

    .carousel-btn {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      background: rgba(0, 0, 0, 0.45);
      color: #fff;
      border: none;
      border-radius: 50%;
      width: 2.2rem;
      height: 2.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: background 0.2s;
    }

    .carousel-btn:hover {
      background: rgba(0, 0, 0, 0.65);
    }

    .carousel-btn.prev {
      left: 0.5rem;
    }

    .carousel-btn.next {
      right: 0.5rem;
    }

    .carousel-counter {
      position: absolute;
      top: 0.5rem;
      right: 0.5rem;
      background: rgba(0, 0, 0, 0.6);
      color: #fff;
      padding: 0.2rem 0.5rem;
      border-radius: 1rem;
      font-size: 0.72rem;
      font-weight: 700;
    }

    /* Documents */
    .pub-doc {
      padding: 0.6rem 1rem;
      border-top: 1px solid #f0f0f0;
    }

    .pub-doc p {
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--light-text);
      margin-bottom: 0.3rem;
    }

    .pub-doc iframe {
      width: 100%;
      height: 280px;
      border: 1px solid #ddd;
      border-radius: 6px;
    }

    /* Actions bar */
    .pub-actions {
      display: flex;
      border-top: 1px solid #e0e0e0;
      padding: 0.1rem 0;
    }

    .pub-action-btn {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
      padding: 0.6rem 0;
      background: none;
      border: none;
      color: var(--light-text);
      font-weight: 600;
      font-size: 0.88rem;
      cursor: pointer;
      border-radius: 0;
      transition: background 0.15s, color 0.15s;
    }

    .pub-action-btn:hover {
      background: #f0f2f5;
      color: var(--primary-color);
    }

    .pub-action-btn.liked {
      color: var(--primary-color);
    }

    .pub-action-btn i {
      font-size: 1.1rem;
    }

    /* Comments section */
    .pub-comments {
      background: #f9f9f9;
      border-top: 1px solid #e0e0e0;
      padding: 0.75rem 1rem;
      display: none;
    }

    .pub-comments.open {
      display: block;
    }

    .comment-form {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 0.75rem;
    }

    .comment-input {
      flex: 1;
      padding: 0.45rem 0.9rem;
      border: 1px solid #ddd;
      border-radius: 20px;
      font-size: 0.88rem;
      font-family: inherit;
      outline: none;
      transition: border-color 0.2s;
    }

    .comment-input:focus {
      border-color: var(--primary-color);
    }

    .comment-submit {
      background: var(--primary-color);
      color: #fff;
      border: none;
      border-radius: 20px;
      padding: 0.45rem 1rem;
      font-weight: 600;
      font-size: 0.88rem;
      cursor: pointer;
      transition: background 0.2s;
    }

    .comment-submit:hover {
      background: var(--primary-hover);
    }

    .comment-item {
      padding: 0.4rem 0;
      border-bottom: 1px solid #eee;
    }

    .comment-item:last-child {
      border-bottom: none;
    }

    .comment-author {
      font-weight: 600;
      font-size: 0.85rem;
      color: var(--text-color);
    }

    .comment-text {
      font-size: 0.85rem;
      color: var(--light-text);
    }

    .pub-empty {
      text-align: center;
      padding: 3rem 1rem;
      color: var(--light-text);
      font-size: 0.95rem;
    }

    .pub-empty i {
      font-size: 2.5rem;
      margin-bottom: 0.75rem;
      display: block;
      color: #ccc;
    }
  </style>
</head>

<body>
  <header class="header">
    <div class="container">
      <div class="logo-section">
        <a href="/"><img src="/images/logo-removebg-preview.png" alt="BookHive Logo" class="logo"></a>
      </div>
      <nav class="nav-menu">
        <a href="/news" class="nav-link"><i class="fas fa-newspaper"></i> News</a>
        <a href="/publications" class="nav-link active"><i class="fas fa-book-open"></i> Publications</a>
        <a href="/bookhive" class="nav-link"><i class="fas fa-book"></i> BookHive</a>
        <a href="/community" class="nav-link"><i class="fas fa-comments"></i> Community</a>
        <a href="/notifications" class="nav-link"><i class="fas fa-bell"></i> Notifications</a>
        <a href="/account" class="nav-link"><i class="fas fa-user"></i> Account</a>
        <a href="/logout" class="nav-link"><i class="fas fa-sign-out-alt"></i> Logout</a>
      </nav>
    </div>
  </header>

  <main>
    <div class="pub-page-wrap">
      <h2 class="pub-page-title">Publications</h2>

      <% if (user) { %>
        <!-- Post Composer -->
        <section class="pub-composer">
          <h3>Share Your Thoughts</h3>
          <form id="create-publication-form" enctype="multipart/form-data">
            <div id="publication-editor-container">
              <div id="publication-editor"></div>
            </div>
            <input type="hidden" id="publication-content" name="content">

            <label for="publication-files" class="pub-file-label">
              <i class="fas fa-photo-video"></i> Add Images or Documents
            </label>
            <input type="file" id="publication-files" name="files" accept="image/jpeg,image/png,application/pdf"
              class="hidden" style="display:none" multiple>

            <div id="file-previews"></div>

            <div class="pub-submit-row">
              <button type="submit" id="submit-publication" class="pub-submit-btn">Post</button>
            </div>
          </form>
          <div id="publicationError" class="pub-msg error" style="display:none"></div>
          <div id="publicationSuccess" class="pub-msg success" style="display:none"></div>
        </section>
        <% } %>

          <!-- Publications Feed -->
          <div id="publications-list">
            <% if (!publications || publications.length===0) { %>
              <div class="pub-empty">
                <i class="fas fa-book-open"></i>
                No publications yet. Be the first to share something!
              </div>
              <% } else { %>
                <% publications.forEach(function(publication) { %>
                  <div class="pub-card" data-publication-id="<%= publication._id %>">

                    <!-- Header -->
                    <div class="pub-card-header">
                      <div class="pub-avatar">
                        <%= publication.postedBy ? publication.postedBy.username.charAt(0).toUpperCase() : '?' %>
                      </div>
                      <div class="pub-meta">
                        <p class="pub-author">
                          <%= publication.postedBy ? publication.postedBy.username : 'Unknown User' %>
                        </p>
                        <span class="pub-date">
                          <%= new Date(publication.createdAt).toLocaleString() %>
                        </span>
                      </div>
                    </div>

                    <!-- Content -->
                    <div class="pub-body"><%- publication.content %></div>

                    <!-- Images -->
                    <% if (publication.images && publication.images.length> 0) { %>
                      <div class="pub-carousel" data-total="<%= publication.images.length %>">
                        <% publication.images.forEach(function(image, index) { %>
                          <img src="/publication-file/<%= publication._id %>/image/<%= index %>"
                            alt="Image <%= index + 1 %>" class="pub-carousel-img <%= index === 0 ? 'active' : '' %>"
                            data-index="<%= index %>">
                          <% }); %>
                            <% if (publication.images.length> 1) { %>
                              <button class="carousel-btn prev"><i class="fas fa-chevron-left"></i></button>
                              <button class="carousel-btn next"><i class="fas fa-chevron-right"></i></button>
                              <div class="carousel-counter">1 / <%= publication.images.length %>
                              </div>
                              <% } %>
                      </div>
                      <% } %>

                        <!-- Documents -->
                        <% if (publication.documents && publication.documents.length> 0) { %>
                          <% publication.documents.forEach(function(doc, index) { %>
                            <div class="pub-doc">
                              <p><i class="fas fa-file-pdf"></i>
                                <%= doc.filename %>
                              </p>
                              <iframe src="/publication-file/<%= publication._id %>/document/<%= index %>"></iframe>
                            </div>
                            <% }); %>
                              <% } %>

                                <!-- Actions -->
                                <div class="pub-actions">
                                  <% const isLiked=user && publication.likes.some(id=> id.toString() ===
                                    user._id.toString()); %>
                                    <button class="pub-action-btn like-button <%= isLiked ? 'liked' : '' %>">
                                      <i class="<%= isLiked ? 'fas' : 'far' %> fa-thumbs-up"></i>
                                      <span class="like-text">
                                        <%= isLiked ? 'Liked' : 'Like' %>
                                      </span>
                                      <span class="like-count">(<%= publication.likeCount || 0 %>)</span>
                                    </button>
                                    <button class="pub-action-btn comment-toggle">
                                      <i class="far fa-comment-dots"></i> Comment
                                    </button>
                                </div>

                                <!-- Comments -->
                                <div class="pub-comments">
                                  <form class="comment-form">
                                    <input name="content" class="comment-input" placeholder="Write a comment…" required>
                                    <button type="submit" class="comment-submit">Post</button>
                                  </form>
                                  <div class="comments-list">
                                    <% (comments[publication._id.toString()] || []).forEach(function(comment) { %>
                                      <div class="comment-item" data-id="<%= comment._id %>">
                                        <p class="comment-author">
                                          <%= comment.user ? comment.user.username : 'Unknown' %>
                                        </p>
                                        <p class="comment-text">
                                          <%= comment.content %>
                                        </p>
                                      </div>
                                      <% }); %>
                                  </div>
                                </div>

                  </div>
                  <% }); %>
                    <% } %>
          </div>
    </div>
  </main>

  <% if (user) { %>
    <script>window.currentUserId = '<%= user._id %>';</script>
    <% } %>

      <footer>
        <div class="container">
          <p>© 2025 BookHive. All rights reserved.</p>
        </div>
      </footer>

      <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
      <script src="/socket.io/socket.io.js"></script>

      <script>
        document.addEventListener('DOMContentLoaded', () => {

          // ── Composer (only present when user is logged in) ─────────────────────
          const editorEl = document.getElementById('publication-editor');
          if (editorEl) {
            const quill = new Quill('#publication-editor', {
              theme: 'snow',
              placeholder: "What's on your mind?",
              modules: {
                toolbar: [
                  ['bold', 'italic', 'underline'],
                  [{ list: 'ordered' }, { list: 'bullet' }],
                  ['link'],
                  ['clean']
                ]
              }
            });

            const fileInput = document.getElementById('publication-files');
            const filePreviews = document.getElementById('file-previews');



            // Show previews when files are selected
            fileInput.addEventListener('change', () => {
              filePreviews.innerHTML = '';
              Array.from(fileInput.files).forEach(file => {
                if (file.type.startsWith('image/')) {
                  const img = document.createElement('img');
                  img.src = URL.createObjectURL(file);
                  filePreviews.appendChild(img);
                } else {
                  const div = document.createElement('div');
                  div.style.cssText = 'font-size:0.75rem;color:#555;padding:0.25rem;background:#f0f0f0;border-radius:4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;';
                  div.textContent = '📄 ' + file.name;
                  filePreviews.appendChild(div);
                }
              });
            });

            // ── Publish form ─────────────────────────────────────────────────────────
            document.getElementById('create-publication-form').addEventListener('submit', async (e) => {
              e.preventDefault();
              const errorEl = document.getElementById('publicationError');
              const successEl = document.getElementById('publicationSuccess');
              const btn = document.getElementById('submit-publication');
              errorEl.style.display = 'none';
              successEl.style.display = 'none';

              document.getElementById('publication-content').value = quill.root.innerHTML.trim();
              const content = quill.getText().trim();
              if (!content && fileInput.files.length === 0) {
                errorEl.textContent = 'Please write something or attach a file.';
                errorEl.style.display = 'block';
                return;
              }

              btn.disabled = true;
              btn.textContent = 'Posting…';

              try {
                const formData = new FormData(e.target);
                const res = await fetch('/publication', { method: 'POST', body: formData });
                const data = await res.json();
                if (data.success) {
                  quill.setContents([]);
                  fileInput.value = '';
                  filePreviews.innerHTML = '';
                  successEl.textContent = 'Published successfully!';
                  successEl.style.display = 'block';
                  setTimeout(() => location.reload(), 800);
                } else {
                  errorEl.textContent = data.message || 'Failed to publish.';
                  errorEl.style.display = 'block';
                }
              } catch {
                errorEl.textContent = 'Network error. Please try again.';
                errorEl.style.display = 'block';
              } finally {
                btn.disabled = false;
                btn.textContent = 'Post';
              }
            });

          } // end if (editorEl)

          // ── Image Carousels ───────────────────────────────────────────────
          document.querySelectorAll('.pub-carousel').forEach(carousel => {
            const images = carousel.querySelectorAll('.pub-carousel-img');
            const counter = carousel.querySelector('.carousel-counter');
            let current = 0;
            function showImage(idx) {
              images[current].classList.remove('active');
              current = (idx + images.length) % images.length;
              images[current].classList.add('active');
              if (counter) counter.textContent = `${current + 1} / ${images.length}`;
            }
            carousel.querySelector('.prev')?.addEventListener('click', () => showImage(current - 1));
            carousel.querySelector('.next')?.addEventListener('click', () => showImage(current + 1));
          });

          // ── Like ──────────────────────────────────────────────────────────────────────
          document.querySelectorAll('.like-button').forEach(btn => {
            btn.addEventListener('click', async () => {
              const card = btn.closest('.pub-card');
              const pubId = card.dataset.publicationId;
              try {
                const res = await fetch(`/publication/${pubId}/like`, { method: 'POST' });
                const data = await res.json();
                if (data.success) {
                  const liked = data.isLiked;
                  btn.classList.toggle('liked', liked);
                  btn.querySelector('i').className = liked ? 'fas fa-thumbs-up' : 'far fa-thumbs-up';
                  btn.querySelector('.like-text').textContent = liked ? 'Liked' : 'Like';
                  btn.querySelector('.like-count').textContent = `(${data.likeCount})`;
                }
              } catch { /* silent */ }
            });
          });

          // ── Comments toggle ────────────────────────────────────────────────────────────
          document.querySelectorAll('.comment-toggle').forEach(btn => {
            btn.addEventListener('click', () => {
              const section = btn.closest('.pub-card').querySelector('.pub-comments');
              section.classList.toggle('open');
            });
          });

          // ── Comment submit ───────────────────────────────────────────────────────────────
          document.querySelectorAll('.comment-form').forEach(form => {
            form.addEventListener('submit', async (e) => {
              e.preventDefault();
              const card = form.closest('.pub-card');
              const pubId = card.dataset.publicationId;
              const input = form.querySelector('.comment-input');
              const content = input.value.trim();
              if (!content) return;
              try {
                const res = await fetch(`/publication/${pubId}/comment`, {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ content })
                });
                const data = await res.json();
                if (data.success && data.comment) {
                  const list = card.querySelector('.comments-list');
                  const div = document.createElement('div');
                  div.className = 'comment-item';
                  div.innerHTML = `<p class="comment-author">${data.comment.user?.username || 'You'}</p>
                                   <p class="comment-text">${data.comment.content}</p>`;
                  list.prepend(div);
                  input.value = '';
                }
              } catch { /* silent */ }
            });
          });

        }); // end DOMContentLoaded
      </script>

      <%- include('partials/chatbot') %>
        <script src="/js/chatbot.js"></script>
        <script src="/js/responsive-handler.js"></script>
</body>

</html>